{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@anthropic/mcp-server-filesystem", "/home/user"],
      "env": {
        "API_KEY": "sk-live-abc123def456"
      }
    },
    "shell-runner": {
      "command": "python",
      "args": ["-m", "mcp_shell_server"],
